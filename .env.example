# Copy to `.env` (gitignored) or set in Vercel project env vars.
# When BOTH are present the app's data layer can use Supabase instead of the
# in-memory demo store (see src/data/supabase/README.md). The anon key is a
# public client key — RLS policies, not secrecy, protect your data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
